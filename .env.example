# Supabase Database Configuration
# Get these from your Supabase project dashboard: Project Settings → Database

# Connection pooling (for serverless/edge functions)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Direct connection (for migrations)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase Auth (optional - for future user authentication)
# NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# Vercel Blob (Required for file uploads)
# Get this from Vercel dashboard: Project Settings → Storage → Blob
# Or run: npx vercel env add BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN="your-blob-token-here"

# Job Search Settings
RATE_LIMIT_PER_DAY=1

# Keywords for job search (comma-separated)
KEYWORDS="software engineer,developer,full stack"

# Target roles (comma-separated)
TARGET_ROLES="Senior Software Engineer,Full Stack Developer"

# Optional: Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# Optional: Vercel Speed Insights  
# NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS=""